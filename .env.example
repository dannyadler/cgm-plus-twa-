# Copy this file to .env and fill in real values for local dev.
# In production, set these in the Netlify dashboard (Site Settings > Environment Variables).

# App-level password that gates the login function.
APP_PASSWORD=replace-me

# BioT backend.
BIOT_API_BASE=https://api.dev.demo2.biot-med.com
BIOT_PATIENT_USER=replace-with-patient-email
BIOT_PATIENT_PASS=replace-me
BIOT_CLINICIAN_USER=replace-with-clinician-email
BIOT_CLINICIAN_PASS=replace-me
BIOT_PATIENT_ID=00000000-0000-0000-0000-000000000000

# Local dev values. For production, swap to your deployed site:
#   ALLOWED_ORIGIN=https://your-site.netlify.app
#   WEBAUTHN_RP_ID=your-site.netlify.app
ALLOWED_ORIGIN=http://localhost:8888
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=CGM Plus
